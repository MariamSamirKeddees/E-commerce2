# Copy to .env and fill in every value: cp .env.example .env
# Docker Compose loads .env automatically. Do not commit .env.

# Local dev: leave unset (defaults to ecommerce-api:local). Production: set to your Docker Hub image.
# DOCKER_IMAGE=your-dockerhub-username/ecommerce-api:latest

# ASP.NET Core environment (Development | Production)
ASPNETCORE_ENVIRONMENT=

# Host ports — pick free ports on your server (host nginx proxies to API_PORT)
API_PORT=
MSSQL_PORT=

# SQL Server
MSSQL_SA_PASSWORD=

# ASP.NET Core — use the same password as MSSQL_SA_PASSWORD in the connection string
ConnectionStrings__DefaultConnection=
Jwt__SigningKey=

# Optional
# Authentication__Google__ClientId=
# Authentication__Google__ClientSecret=
# Smtp__Host=
# Smtp__Username=
# Smtp__Password=
# Twilio__AccountSid=
# Twilio__AuthToken=
